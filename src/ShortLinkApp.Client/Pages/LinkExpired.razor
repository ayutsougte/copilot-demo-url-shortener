@page "/link-expired"
@layout MainLayout

<PageTitle>Link Expired – ShortLink</PageTitle>

<div class="error-page">
    <div class="error-icon error-icon-expired" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
            <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
        </svg>
    </div>

    <h1 class="error-title">Link Expired</h1>

    @if (!string.IsNullOrEmpty(ShortCode))
    {
        <p class="error-subtitle">
            The short link <code class="error-code">@ShortCode</code> has expired and is no longer active.
        </p>
    }
    else
    {
        <p class="error-subtitle">
            The short link you followed has expired and is no longer active.
        </p>
    }

    <p class="error-desc">
        This link reached its expiration date and can no longer be used.
        Please contact the person who shared it with you to request an updated link.
    </p>

    <div class="error-actions">
        <NavLink class="btn btn-primary" href="/">Go to Dashboard</NavLink>
        <NavLink class="btn btn-outline-secondary" href="create">Create a Link</NavLink>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "code")]
    public string? ShortCode { get; set; }
}
