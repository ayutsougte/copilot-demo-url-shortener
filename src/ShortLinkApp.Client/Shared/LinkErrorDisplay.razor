<div class="error-page">
    <div class="error-icon @(IsExpired ? "error-icon-expired" : "error-icon-notfound")" aria-hidden="true">
        @if (IsExpired)
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
            </svg>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" viewBox="0 0 16 16">
                <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1.002 1.002 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4.018 4.018 0 0 1-.128-1.287z"/>
                <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243L6.586 4.672z"/>
            </svg>
        }
    </div>

    <h1 class="error-title">@(IsExpired ? "Link Expired" : "Link Not Found")</h1>

    @if (!string.IsNullOrEmpty(ShortCode))
    {
        <p class="error-subtitle">
            @if (IsExpired)
            {
                <span>The short link <code class="error-code">@ShortCode</code> has expired and is no longer active.</span>
            }
            else
            {
                <span>The short link <code class="error-code">@ShortCode</code> does not exist.</span>
            }
        </p>
    }
    else
    {
        <p class="error-subtitle">
            @(IsExpired
                ? "The short link you followed has expired and is no longer active."
                : "The short link you followed does not exist.")
        </p>
    }

    <p class="error-desc">
        @if (IsExpired)
        {
            <span>This link reached its expiration date and can no longer be used.
            Please contact the person who shared it with you to request an updated link.</span>
        }
        else
        {
            <span>It may have been deleted, or the URL may have been typed incorrectly.
            Please check the link and try again, or contact the person who shared it with you.</span>
        }
    </p>

    <div class="error-actions">
        <NavLink class="btn btn-primary" href="/">Go to Dashboard</NavLink>
        <NavLink class="btn btn-outline-secondary" href="create">Create a Link</NavLink>
    </div>
</div>

@code {
    [Parameter] public bool IsExpired { get; set; }
    [Parameter] public string? ShortCode { get; set; }
}
