@page "/analytics"

<PageTitle>Analytics – ShortLink</PageTitle>

<div class="page-header mb-4">
    <h1 class="page-title">Analytics</h1>
    <p class="page-subtitle">Track click counts and engagement trends for your short links.</p>
</div>

@if (_linksLoadError is not null)
{
    <div class="alert alert-danger" role="alert">
        <strong>Failed to load links.</strong> @_linksLoadError
    </div>
}
else if (_linksLoading)
{
    <div class="loading-state" role="status" aria-live="polite">
        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
        Loading links…
    </div>
}
else if (_links.Count == 0)
{
    <div class="placeholder-panel">
        <div class="placeholder-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                <path d="M1 11a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1v-3zm5-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7zm5-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V2z"/>
            </svg>
        </div>
        <h2 class="placeholder-title">No links yet</h2>
        <p class="placeholder-desc">
            Create a short link first, then come back here to view its click analytics.
        </p>
        <NavLink class="btn btn-primary" href="create">Create your first link</NavLink>
    </div>
}
else
{
    <!-- Link selector -->
    <div class="analytics-selector mb-4">
        <label for="link-select" class="form-label analytics-selector-label">
            Select a link to view analytics:
        </label>
        <div class="link-search-container @(_dropdownOpen ? "open" : "")">
            <div class="link-search-input-wrapper">
                <svg class="link-search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11"/>
                </svg>
                <input id="link-select"
                       type="text"
                       class="link-search-input"
                       placeholder="Search by short code, alias, or URL…"
                       value="@_searchText"
                       @oninput="OnSearchInput"
                       @onfocus="OpenDropdown"
                       @onblur="CloseDropdown"
                       @onkeydown="OnSearchKeyDown"
                       autocomplete="off"
                       aria-label="Search and select a link for analytics"
                       aria-expanded="@(_dropdownOpen ? "true" : "false")"
                       aria-haspopup="listbox"
                       role="combobox" />
                @if (_selectedLinkId.HasValue || !string.IsNullOrEmpty(_searchText))
                {
                    <button type="button"
                            class="link-search-clear"
                            @onclick="ClearSelection"
                            title="Clear selection"
                            aria-label="Clear selection">×</button>
                }
            </div>
            @if (_dropdownOpen)
            {
                <div class="link-dropdown" role="listbox" id="link-select-dropdown">
                    @if (_filteredLinks.Count > 0)
                    {
                        @if (_links.Count > MinLinksForCountBadge)
                        {
                            <div class="link-dropdown-count">
                                @if (_filteredLinks.Count < _links.Count)
                                {
                                    <span>@_filteredLinks.Count of @_links.Count links</span>
                                }
                                else
                                {
                                    <span>@_links.Count links — type to filter</span>
                                }
                            </div>
                        }
                        @foreach (var link in _filteredLinks.Take(MaxDropdownItems))
                        {
                            var isSelected = _selectedLinkId == link.Id;
                            <div class="link-dropdown-item @(isSelected ? "selected" : "")"
                                 role="option"
                                 aria-selected="@(isSelected ? "true" : "false")"
                                 @onclick="() => SelectLink(link)">
                                <span class="link-dropdown-code">@link.ShortCode@(link.CustomAlias is not null ? $" ({link.CustomAlias})" : "")</span>
                                <span class="link-dropdown-url">@TruncateUrl(link.OriginalUrl)</span>
                            </div>
                        }
                        @if (_filteredLinks.Count > MaxDropdownItems)
                        {
                            <div class="link-dropdown-more">
                                +@(_filteredLinks.Count - MaxDropdownItems) more — refine your search
                            </div>
                        }
                    }
                    else
                    {
                        <div class="link-dropdown-no-results">No links match "@_searchText"</div>
                    }
                </div>
            }
        </div>
    </div>

    @if (_selectedLinkId.HasValue)
    {
        @if (_analyticsLoading)
        {
            <div class="loading-state" role="status" aria-live="polite">
                <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                Loading analytics…
            </div>
        }
        else if (_analyticsError is not null)
        {
            <div class="alert alert-danger" role="alert">
                <strong>Failed to load analytics.</strong> @_analyticsError
            </div>
        }
        else if (_analytics is not null)
        {
            <!-- Stats row -->
            <div class="analytics-stats-row mb-4">
                <div class="analytics-stat-card">
                    <div class="analytics-stat-value">@_analytics.TotalClicks</div>
                    <div class="analytics-stat-label">Total Clicks</div>
                </div>
                <div class="analytics-stat-card">
                    <div class="analytics-stat-value">@_analytics.ClicksByDate.Count</div>
                    <div class="analytics-stat-label">Days with Clicks</div>
                </div>
                @if (_analytics.ClicksByDate.Count > 0)
                {
                    <div class="analytics-stat-card">
                        <div class="analytics-stat-value">@_analytics.ClicksByDate.Max(d => d.Count)</div>
                        <div class="analytics-stat-label">Peak Day</div>
                    </div>
                }
            </div>

            <!-- Chart -->
            @if (_analytics.ClicksByDate.Count == 0)
            {
                <div class="analytics-no-data-panel">
                    <p class="analytics-no-data-text">No click data recorded for this link yet.</p>
                </div>
            }
            else
            {
                <div class="analytics-chart-card">
                    <h2 class="analytics-chart-title">Clicks Over Time</h2>
                    <div class="analytics-chart-wrapper">
                        @BuildChartSvg(_analytics.ClicksByDate)
                    </div>
                </div>
            }
        }
    }
}
